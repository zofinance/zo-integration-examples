# network (mainnet, testnet)
NETWORK=mainnet

# RPC URL (optional; public defaults used if unset)
SUI_MAINNET_RPC_URL=https://fullnode.mainnet.sui.io
SUI_TESTNET_RPC_URL=https://fullnode.testnet.sui.io

# Sui wallet private key in Bech32 format (e.g. suiprivkey1...)
# Required. Never commit this file with a real key.
PRIVATE_KEY=